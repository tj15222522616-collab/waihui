{
  "name": "forex-platform-finder",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop research tool for collecting, scoring, filtering, importing, and exporting forex broker information.",
  "author": "Forex Platform Finder",
  "main": "dist-electron/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:main": "esbuild electron/main/index.ts electron/preload.ts --bundle --platform=node --format=cjs --outdir=dist-electron --out-extension:.js=.cjs --external:electron --external:better-sqlite3",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run test && npm run typecheck && npm run build:main && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron:check": "electron --version",
    "electron:install": "cross-env ELECTRON_MIRROR=https://cdn.npmmirror.com/binaries/electron/ node node_modules/electron/install.js",
    "rebuild:native": "electron-builder install-app-deps",
    "dist:win": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.10",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.forexplatformfinder.app",
    "productName": "Forex Platform Finder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
